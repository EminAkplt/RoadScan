# RoadScan ortam değişkenleri — bu dosyayı .env olarak kopyalayın
# cp .env.example .env

# API portu
PORT=3000

# --- PostgreSQL bağlantısı ---
# Seçenek A: Tek satır bağlantı dizesi (varsa bu öncelikli kullanılır)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/roadscan

# Seçenek B: Ayrı ayrı değişkenler
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=roadscan
